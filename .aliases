alias zshconfig='vim ~/.zshrc'
alias vimconfig='vim ~/.vimrc'

alias ve='python3 -m venv ./venv'
alias va='source ./venv/bin/activate'
alias tmux='tmux -2'
alias ipython='jupyter console'
alias hvim='vim -b'

alias lazygit='git add . && git commit -m "." && git push'
alias xclip='pbcopy'

alias jetbrains='open -a "JetBrains Toolbox"'

alias dockerstopall='docker stop $(docker ps -aq)'
alias dockerrmall='docker rm -f $(docker ps -aq)'
alias dockerrmiall='docker rmi -f $(docker images -aq)'
alias dockerdel='dockerstopall || true && dockerrmall || true && dockerrmiall || true'
